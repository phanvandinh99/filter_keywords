# ============================================================
# Cấu hình baidu-keyword-checker (Docker)
# Sao chép file này thành .env rồi chỉnh sửa
# ============================================================

# Bật chế độ Docker (headless, không cần Chrome profile)
DOCKER=1

# File Excel output (đường dẫn trong container)
EXCEL_FILE=/app/data/keywords.xlsx

# ── Chỉ cần khi chạy LOCAL (không dùng Docker) ───────────────
# DOCKER=0
# PROFILE_PATH=C:\Users\DINH\AppData\Local\Google\Chrome\User Data\Profile 9
# CHROME_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
